###
### GLFW
###

WIN32_SRCS = [
    "glfw/src/win32_init.c",
    "glfw/src/win32_joystick.c",
    "glfw/src/win32_monitor.c",
    "glfw/src/win32_thread.c",
    "glfw/src/win32_time.c",
    "glfw/src/win32_window.c",
    "glfw/src/wgl_context.c",
    "glfw/src/win32_joystick.h",
    "glfw/src/win32_platform.h",
    "glfw/src/wgl_context.h", 
]

LINUX_SRCS = [
    "glfw/src/glx_context.c",
    "glfw/src/linux_joystick.c",
    "glfw/src/posix_thread.c",
    "glfw/src/posix_time.c",
    "glfw/src/x11_init.c",
    "glfw/src/x11_monitor.c",
    "glfw/src/x11_window.c",
    "glfw/src/glx_context.h",
    "glfw/src/linux_joystick.h",
    "glfw/src/posix_thread.h",
    "glfw/src/posix_time.h",
    "glfw/src/x11_platform.h",
]

WIN32_DEFINES = [
    "_GLFW_WIN32",
]

LINUX_DEFINES = [
    "_GLFW_HAS_XF86VM",
    "_GLFW_X11",
]

WIN32_LINKOPTS = [
    "-DEFAULTLIB:user32.lib",
    "-DEFAULTLIB:gdi32.lib",
    "-DEFAULTLIB:shell32.lib",
]

LINUX_LINKOPTS = []

cc_library(
    name = "glfw_src",
   
    srcs = [
        "glfw/src/context.c",
        "glfw/src/egl_context.c",
        "glfw/src/init.c",
        "glfw/src/input.c",
        "glfw/src/osmesa_context.c",
        "glfw/src/monitor.c",
        "glfw/src/vulkan.c",
        "glfw/src/window.c",
        "glfw/src/xkb_unicode.c",
        "glfw/src/egl_context.h",
        "glfw/src/internal.h",
        "glfw/src/osmesa_context.h",
        "glfw/src/mappings.h",
        "glfw/src/xkb_unicode.h",
        "glfw/include/GLFW/glfw3.h",
        "glfw/include/GLFW/glfw3native.h",
    ]
    + select({
		"@bazel_tools//src/conditions:windows": WIN32_SRCS,
		"@bazel_tools//src/conditions:linux_x86_64": LINUX_SRCS,
	}),
    defines = select({
		"@bazel_tools//src/conditions:windows": WIN32_DEFINES,
		"@bazel_tools//src/conditions:linux_x86_64": LINUX_DEFINES,
	}),
)

cc_library(
    name = "glfw",
    hdrs = [
        "glfw/include/GLFW/glfw3.h",
        "glfw/include/GLFW/glfw3native.h",
    ],
    linkopts = select({
		"@bazel_tools//src/conditions:windows": WIN32_LINKOPTS,
    	"@bazel_tools//src/conditions:linux_x86_64": LINUX_LINKOPTS,
	}),
    deps = [":glfw_src"],
    includes = ["glfw/include"],
    visibility = ["//visibility:public"],
)

###
### GLAD
###

cc_library(
    name = "glad",
    srcs = ["glad/src/glad.c"],
    hdrs = [
        "glad/include/glad/glad.h",
        "glad/include/KHR/khrplatform.h",
    ],
    includes = ["glad/include"],
    visibility = ["//visibility:public"],
)


###
### GLM
###

cc_library(
    name = "glm",
    srcs = glob([
        "glm/**/*.hpp",
        "glm/**/*.h",
        #"glm/**/*.inl",
    ]),
    hdrs = ["glm/glm.hpp"],
    includes = ["glm/", "./"],
    visibility = ["//visibility:public"],
)

###
### IMGUI
###

cc_library(
    name = "imgui",
    srcs = glob([
        "imgui/*.cpp",
        "imgui/*.h",
    ]),
    hdrs = ["imgui/imgui.h"],
    includes = ["imgui/"],
    deps = [
        ":glad",
        ":glfw",
        ],
    visibility = ["//visibility:public"],
)

###
### ImNodes
###

cc_library(
    name = "imnodes",
    srcs = [
        "imnodes/imnodes.cpp",
    ],
    hdrs = ["imnodes/imnodes.h"],
    includes = ["imnodes/"],
    deps = [":imgui"],
    visibility = ["//visibility:public"],
)

###
### nlohmann/JSON
###

cc_library(
    name = "nlohmann_json",
    hdrs = ["json/json.hpp"],
    includes = ["json"],
    visibility = ["//visibility:public"],
)

###
### spdlog
###

cc_library(
    name = "spdlog",
    srcs = glob([
        "spdlog/src/*.cpp",
    ]),
    hdrs = glob([
        "spdlog/include/**/*.h",
    ]),
    includes = ["spdlog/include/"],
    defines=[
      "SPDLOG_COMPILED_LIB"
    ],
    visibility = ["//visibility:public"],
)

###
### pybind11
###

cc_library(
    name = "pybind",
    hdrs = glob([
            "pybind/include/pybind11/**/*.h",
        ],
        exclude = ["pybind/include/pybind11/common.h"],
    ),
    includes = ["pybind/include/"],
    visibility = ["//visibility:public"],
)